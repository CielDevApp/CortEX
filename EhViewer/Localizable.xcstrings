    "%lld件のインデックス（gid/token/タイトル/URL）をJSON保存。BANされても手元にデータが残ります。復元するとお気に入りキャッシュにマージされます。": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichert %lld Einträge (gid/token/Titel/URL) als JSON. Daten bleiben auch bei BAN erhalten. Wiederherstellung wird mit Favoriten-Cache zusammengeführt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save %lld entries (gid/token/title/URL) as JSON. Your data survives even if banned. Restore merges into favorites cache."
          }
        },
        "es": {
