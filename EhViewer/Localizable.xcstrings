      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wendet Tonkurve, Histogramm und Schärfe an. Bei HDR wird es integriert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Applies tone curve, histogram equalization & sharpness. When HDR is ON, HDR processing is integrated there."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica curva tonal, ecualización e nitidez. Si HDR está ON, se integra allí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Applique courbe, égalisation et netteté. Si HDR activé, le HDR est intégré."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "톤 커브, 히스토그램 균등화, 샤프니스를 적용. HDR ON 시 HDR 처리가 통합됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用色调曲线、直方图均衡化和锐化。开启HDR时，HDR处理将整合其中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "套用色調曲線、直方圖均衡化和銳化。開啟HDR時，HDR處理將整合其中。"
          }
        }
      }
