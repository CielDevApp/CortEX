            "value": "安全模式關閉 — 存在 BAN 風險"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "안전 모드 OFF — BAN 리스크 있음"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sicherheitsmodus AUS — BAN-Risiko"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode Sécurité OFF — risque de BAN"
          }
